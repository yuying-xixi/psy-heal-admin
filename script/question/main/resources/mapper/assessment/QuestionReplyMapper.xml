<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.assessment.mapper.QuestionReplyMapper">
    
    <resultMap type="QuestionReply" id="QuestionReplyResult">
        <result property="id"    column="id"    />
        <result property="replyContent"    column="reply_content"    />
        <result property="replyTime"    column="reply_time"    />
        <result property="userId"    column="user_id"    />
        <result property="consultId"    column="consult_id"    />
        <result property="questionId"    column="question_id"    />
        <result property="isBest"    column="is_best"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectQuestionReplyVo">
        select id, reply_content, reply_time, user_id, consult_id, question_id, is_best, del_flag, create_by, create_time, update_by, update_time from question_reply
    </sql>

    <select id="selectQuestionReplyList" parameterType="QuestionReply" resultMap="QuestionReplyResult">
        <include refid="selectQuestionReplyVo"/>
        <where>  
            <if test="replyContent != null  and replyContent != ''"> and reply_content = #{replyContent}</if>
            <if test="params.beginReplyTime != null and params.beginReplyTime != '' and params.endReplyTime != null and params.endReplyTime != ''"> and reply_time between #{params.beginReplyTime} and #{params.endReplyTime}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="consultId != null "> and consult_id = #{consultId}</if>
            <if test="questionId != null "> and question_id = #{questionId}</if>
            <if test="isBest != null "> and is_best = #{isBest}</if>
            <if test="createBy != null  and createBy != ''"> and create_by = #{createBy}</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''"> and create_time between #{params.beginCreateTime} and #{params.endCreateTime}</if>
            <if test="updateBy != null  and updateBy != ''"> and update_by = #{updateBy}</if>
            <if test="params.beginUpdateTime != null and params.beginUpdateTime != '' and params.endUpdateTime != null and params.endUpdateTime != ''"> and update_time between #{params.beginUpdateTime} and #{params.endUpdateTime}</if>
        </where>
    </select>
    
    <select id="selectQuestionReplyById" parameterType="Long" resultMap="QuestionReplyResult">
        <include refid="selectQuestionReplyVo"/>
        where id = #{id}
    </select>

    <insert id="insertQuestionReply" parameterType="QuestionReply" useGeneratedKeys="true" keyProperty="id">
        insert into question_reply
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="replyContent != null and replyContent != ''">reply_content,</if>
            <if test="replyTime != null">reply_time,</if>
            <if test="userId != null">user_id,</if>
            <if test="consultId != null">consult_id,</if>
            <if test="questionId != null">question_id,</if>
            <if test="isBest != null">is_best,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="replyContent != null and replyContent != ''">#{replyContent},</if>
            <if test="replyTime != null">#{replyTime},</if>
            <if test="userId != null">#{userId},</if>
            <if test="consultId != null">#{consultId},</if>
            <if test="questionId != null">#{questionId},</if>
            <if test="isBest != null">#{isBest},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateQuestionReply" parameterType="QuestionReply">
        update question_reply
        <trim prefix="SET" suffixOverrides=",">
            <if test="replyContent != null and replyContent != ''">reply_content = #{replyContent},</if>
            <if test="replyTime != null">reply_time = #{replyTime},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="consultId != null">consult_id = #{consultId},</if>
            <if test="questionId != null">question_id = #{questionId},</if>
            <if test="isBest != null">is_best = #{isBest},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteQuestionReplyById" parameterType="Long">
        delete from question_reply where id = #{id}
    </delete>

    <delete id="deleteQuestionReplyByIds" parameterType="String">
        delete from question_reply where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>