<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.content.mapper.FmAudioMapper">
    
    <resultMap type="FmAudio" id="FmAudioResult">
        <result property="id"    column="id"    />
        <result property="fmId"    column="fm_id"    />
        <result property="audioName"    column="audio_name"    />
        <result property="audioUrl"    column="audio_url"    />
        <result property="audioDuration"    column="audio_duration"    />
        <result property="audioSize"    column="audio_size"    />
        <result property="sortOrder"    column="sort_order"    />
        <result property="playCount"    column="play_count"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectFmAudioVo">
        select id, fm_id, audio_name, audio_url, audio_duration, audio_size, sort_order, play_count, del_flag, create_by, create_time, update_by, update_time from fm_audio
    </sql>

    <select id="selectFmAudioList" parameterType="FmAudio" resultMap="FmAudioResult">
        <include refid="selectFmAudioVo"/>
        <where>  
            <if test="fmId != null "> and fm_id = #{fmId}</if>
            <if test="audioName != null  and audioName != ''"> and audio_name like concat('%', #{audioName}, '%')</if>
            <if test="audioDuration != null "> and audio_duration &gt;= #{audioDuration}</if>
            <if test="audioSize != null "> and audio_size &gt;= #{audioSize}</if>
            <if test="playCount != null "> and play_count = #{playCount}</if>
            <if test="createBy != null  and createBy != ''"> and create_by = #{createBy}</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''"> and create_time between #{params.beginCreateTime} and #{params.endCreateTime}</if>
            <if test="updateBy != null  and updateBy != ''"> and update_by = #{updateBy}</if>
            <if test="params.beginUpdateTime != null and params.beginUpdateTime != '' and params.endUpdateTime != null and params.endUpdateTime != ''"> and update_time between #{params.beginUpdateTime} and #{params.endUpdateTime}</if>
        </where>
    </select>
    
    <select id="selectFmAudioById" parameterType="Long" resultMap="FmAudioResult">
        <include refid="selectFmAudioVo"/>
        where id = #{id}
    </select>

    <insert id="insertFmAudio" parameterType="FmAudio" useGeneratedKeys="true" keyProperty="id">
        insert into fm_audio
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="fmId != null">fm_id,</if>
            <if test="audioName != null and audioName != ''">audio_name,</if>
            <if test="audioUrl != null and audioUrl != ''">audio_url,</if>
            <if test="audioDuration != null">audio_duration,</if>
            <if test="audioSize != null">audio_size,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="playCount != null">play_count,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="fmId != null">#{fmId},</if>
            <if test="audioName != null and audioName != ''">#{audioName},</if>
            <if test="audioUrl != null and audioUrl != ''">#{audioUrl},</if>
            <if test="audioDuration != null">#{audioDuration},</if>
            <if test="audioSize != null">#{audioSize},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="playCount != null">#{playCount},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateFmAudio" parameterType="FmAudio">
        update fm_audio
        <trim prefix="SET" suffixOverrides=",">
            <if test="fmId != null">fm_id = #{fmId},</if>
            <if test="audioName != null and audioName != ''">audio_name = #{audioName},</if>
            <if test="audioUrl != null and audioUrl != ''">audio_url = #{audioUrl},</if>
            <if test="audioDuration != null">audio_duration = #{audioDuration},</if>
            <if test="audioSize != null">audio_size = #{audioSize},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="playCount != null">play_count = #{playCount},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteFmAudioById" parameterType="Long">
        delete from fm_audio where id = #{id}
    </delete>

    <delete id="deleteFmAudioByIds" parameterType="String">
        delete from fm_audio where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>